{
  "cleanupPeriodDays": 365,
  "permissions": {
    "allow": [
      "Bash(mkdir -p */.claude/gates)",
      "Bash(mkdir -p */.claude/handoffs)",
      "Bash(touch */.claude/handoffs/*)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/writ-rag-inject.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/writ-context-tracker.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/check-gate-approval.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/pre-validate-file.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/enforce-final-gate.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/validate-file.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/validate-handoff.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/inject-tier-workflow.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/auto-approve-gate.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/validate-rules.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/friction-logger.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/writ-pretool-rag.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/writ-posttool-rag.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/validate-exit-plan.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/writ-read-rag.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/writ-subagent-start.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/writ-subagent-stop.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/enforce-violations.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/track-failed-writes.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/writ-precompact.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/writ-postcompact.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/writ-session-end.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/writ-pre-write-dispatch.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/writ-cwd-changed.sh)",
      "Bash(bash $HOME/.claude/skills/writ/.claude/hooks/writ-instructions-loaded.sh)"
    ],
    "deny": [
      "Bash(touch */.claude/gates/*)",
      "Bash(*touch*gates*approved*)",
      "Bash(*>.claude/gates/*)",
      "Bash(*gate*approve*)",
      "Read(.env*)",
      "Read(**/credentials*)",
      "Read(**/secrets*)",
      "Read(**/.ssh/*)",
      "Read(*.key)",
      "Read(*.pem)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/auto-approve-gate.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/writ-rag-inject.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/writ-subagent-start.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/writ-subagent-stop.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/writ-context-tracker.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/friction-logger.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/enforce-violations.sh"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/track-failed-writes.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/writ-precompact.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/writ-postcompact.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/writ-session-end.sh"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/writ-cwd-changed.sh"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/writ-instructions-loaded.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/validate-exit-plan.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/writ-read-rag.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/writ-pre-write-dispatch.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/pre-validate-file.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/inject-tier-workflow.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/validate-file.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/validate-handoff.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/validate-rules.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/skills/writ/.claude/hooks/writ-posttool-rag.sh"
          }
        ]
      }
    ]
  }
}
